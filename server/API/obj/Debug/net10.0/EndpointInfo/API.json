  "components": {
    "schemas": {
      "CategoryEnum": {
        "type": "integer"
      },
      "ExpenseDashboardRequest": {
        "type": "object",
        "properties": {
          "startDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "endDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "category": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/CategoryEnum"
              }
            ]
          },
          "searchText": {
            "type": [
              "null",
              "string"
            ]
          },
          "page": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "pageSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "sorting": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageSorting"
              }
            ]
          }
        }
      },
      "ExpenseDto": {
        "type": "object",
        "properties": {
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "category": {
            "$ref": "#/components/schemas/CategoryEnum"
          },
          "description": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "payment": {
            "$ref": "#/components/schemas/PaymentTypeEnum"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PageSorting": {
        "type": "object",
        "properties": {
          "field": {
            "type": [
              "null",
              "string"
            ]
          },
          "direction": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "PaymentTypeEnum": {
        "type": "integer"
      }
    }
